#include <iostream>
#include <string>
#include <cstdlib>
#include <ctime>
#include <chrono>
using namespace std;

// --- Структура сделки ---
struct Deal {
    string contractNumber;
    string date;
    string owner;
    double price;
    int salePeriod;
    string status;
};

// --- Словарь ---
struct Dictionary {
    Deal data[100];
    int size = 0;

    void Insert(Deal d) { data[size++] = d; }

    void FindByOwner(string owner) {
        for (int i = 0; i < size; i++)
            if (data[i].owner == owner)
                cout << data[i].contractNumber << " | " << data[i].owner
                     << " | " << data[i].price << " | " << data[i].status << endl;
    }

    double FailedDealsPercentage() {
        int fail = 0;
        for (int i = 0; i < size; i++)
            if (data[i].status == "провал") fail++;
        return 100.0 * fail / size;
    }
};

// --- Узел для хеш-таблицы ---
struct Node {
    string key; // ключ — владелец
    Deal value;
    Node* next;
    Node(string k, Deal v) { key = k; value = v; next = nullptr; }
};

// --- Хеш-функция ---
int hash_func(string s, int size) {
    unsigned long long H = 0;
    unsigned long long p = 31;
    const unsigned long long M = 1315423911ULL;
    for (unsigned char a : s) {
        H = (H + (unsigned long long)a * p) % M;
        p = (p * p) % M;
    }
    return static_cast<int>(H % size);
}

// --- Хеш-таблица через метод цепочек ---
class HashTable {
private:
    size_t SIZE;
    Node** buckets;
public:
    HashTable(size_t size) {
        SIZE = size;
        buckets = new Node*[SIZE];
        for (size_t i = 0; i < SIZE; ++i) buckets[i] = nullptr;
    }

    ~HashTable() { clear(); delete[] buckets; }

    void InsertUpdate(string key, Deal value) {
        int idx = hash_func(key, SIZE);
        Node* cur = buckets[idx];
        while (cur) {
            if (cur->key == key) {
                // Обновление: добавляем новую сделку в голову цепочки
                Node* node = new Node(key, value);
                node->next = cur->next;
                cur->next = node;
                return;
            }
            cur = cur->next;
        }
        Node* node = new Node(key, value);
        node->next = buckets[idx];
        buckets[idx] = node;
    }

    void FindByOwner(string key) {
        int idx = hash_func(key, SIZE);
        Node* cur = buckets[idx];
        while (cur) {
            if (cur->key == key) {
                cout << cur->value.contractNumber << " | " << cur->value.owner
                     << " | " << cur->value.price << " | " << cur->value.status << endl;
            }
            cur = cur->next;
        }
    }

    double FailedDealsPercentage() {
        int fail = 0, total = 0;
        for (size_t i = 0; i < SIZE; i++) {
            Node* cur = buckets[i];
            while (cur) {
                total++;
                if (cur->value.status == "провал") fail++;
                cur = cur->next;
            }
        }
        return 100.0 * fail / total;
    }

    void Print() {
        for (size_t i = 0; i < SIZE; ++i) {
            cout << i << ":";
            Node* cur = buckets[i];
            if (!cur) { cout << " (empty)"; }
            while (cur) {
                cout << " [" << cur->key << " -> " << cur->value.contractNumber << "]";
                cur = cur->next;
            }
            cout << '\n';
        }
    }

    void clear() {
        for (size_t i = 0; i < SIZE; ++i) {
            Node* cur = buckets[i];
            while (cur) {
                Node* nxt = cur->next;
                delete cur;
                cur = nxt;
            }
            buckets[i] = nullptr;
        }
    }
};

// --- Генерация случайных сделок ---
void GenerateDeals(Dictionary& dict, HashTable& table, int count) {
    string owners[] = {"Иванов","Петров","Сидоров","Смирнов","Кузнецов"};
    string status[] = {"успех","провал"};
    for (int i = 0; i < count; i++) {
        Deal d;
        d.contractNumber = to_string(100 + i);
        d.date = "2024";
        d.owner = owners[rand() % 5];
        d.price = 50000 + rand() % 100000;
        d.salePeriod = 10 + rand() % 60;
        d.status = status[rand() % 2];
        dict.Insert(d);
        table.InsertUpdate(d.owner, d);
    }
}

// --- Основная программа ---
int main() {
    srand(time(0));
    const int RECORDS = 50;

    Dictionary dict1, dict2;
    HashTable table1(10), table2(10);

    // Генерация данных
    GenerateDeals(dict1, table1, RECORDS); // Задача 1
    GenerateDeals(dict2, table2, RECORDS); // Задача 2

    string targetOwner = "Иванов";

    // Задача 1: перечень сделок владельца
    cout << "\n=== Задача 1: сделки владельца " << targetOwner << " ===\n";

    auto startDict = chrono::high_resolution_clock::now();
    dict1.FindByOwner(targetOwner);
    auto endDict = chrono::high_resolution_clock::now();

    auto startHash = chrono::high_resolution_clock::now();
    table1.FindByOwner(targetOwner);
    auto endHash = chrono::high_resolution_clock::now();

    cout << "\nВремя поиска в словаре: "
         << chrono::duration_cast<chrono::nanoseconds>(endDict - startDict).count() << " ns\n";
    cout << "Время поиска в хеш-таблице: "
         << chrono::duration_cast<chrono::nanoseconds>(endHash - startHash).count() << " ns\n";

    table1.Print();

    // Задача 2: процент неудачных сделок
    cout << "\n=== Задача 2: процент неудачных сделок ===\n";

    startDict = chrono::high_resolution_clock::now();
    double failedDict = dict2.FailedDealsPercentage();
    endDict = chrono::high_resolution_clock::now();

    startHash = chrono::high_resolution_clock::now();
    double failedHash = table2.FailedDealsPercentage();
    endHash = chrono::high_resolution_clock::now();

    cout << "Словарь: " << failedDict << " % неудачных сделок, время: "
         << chrono::duration_cast<chrono::nanoseconds>(endDict - startDict).count() << " ns\n";
    cout << "Хеш-таблица: " << failedHash << " % неудачных сделок, время: "
         << chrono::duration_cast<chrono::nanoseconds>(endHash - startHash).count() << " ns\n";

    return 0;
}
