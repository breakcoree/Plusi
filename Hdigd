#include <iostream>
#include <string>
#include <cstdlib>
#include <ctime>

using namespace std;

struct Deal {
    string contractNumber;
    string date;
    string owner;
    double price;
    int salePeriod;
    string status;
};

// Узел связного списка для метода цепочек
struct Node {
    Deal value;
    Node* next;

    Node(Deal v) {
        value = v;
        next = nullptr;
    }
};

class HashTable {
private:
    int SIZE;
    Node** buckets;

    int hash_func(const string& s) {
        unsigned long long H = 0;
        unsigned long long p = 31;
        const unsigned long long M = 1315423911ULL;

        for (unsigned char a : s) {
            H = (H + (unsigned long long)a * p) % M;
            p = (p * p) % M;
        }
        return H % SIZE;
    }

public:
    HashTable(int size) {
        SIZE = size;
        buckets = new Node*[SIZE];
        for (int i = 0; i < SIZE; i++)
            buckets[i] = nullptr;
    }

    // Вставка через метод цепочек
    void Insert(Deal d) {
        int idx = hash_func(d.owner);
        Node* node = new Node(d);
        node->next = buckets[idx]; // добавляем в голову списка
        buckets[idx] = node;

        cout << "Inserted " << d.owner << " at bucket " << idx << endl;
    }

    // Поиск по владельцу с выводом цепочки
    void FindByOwner(const string& owner) {
        int idx = hash_func(owner);
        Node* cur = buckets[idx];

        cout << "Searching bucket " << idx << ":\n";

        bool found = false;
        while (cur) {
            if (cur->value.owner == owner) {
                cout << "  Contract: " << cur->value.contractNumber
                     << ", Owner: " << cur->value.owner
                     << ", Price: " << cur->value.price << endl;
                found = true;
            }
            cur = cur->next;
        }
        if (!found) cout << "  No deals found for " << owner << endl;
    }

    // Показать всю хэш-таблицу
    void PrintTable() {
        cout << "\nHash Table Buckets:\n";
        for (int i = 0; i < SIZE; i++) {
            cout << "[" << i << "]: ";
            Node* cur = buckets[i];
            while (cur) {
                cout << cur->value.owner << " -> ";
                cur = cur->next;
            }
            cout << "NULL\n";
        }
    }
};

void GenerateDeals(HashTable& table) {
    string status[] = {"успех","провал"};

    // Создаём коллизию намеренно
    Deal d1 = {"101", "2024", "Иванов", 120000, 30, "успех"};
    Deal d2 = {"102", "2024", "ИвановX", 150000, 45, "провал"};

    table.Insert(d1);
    table.Insert(d2);

    // Остальные случайные сделки
    string owners[] = {"Петров","Сидоров","Смирнов","Кузнецов"};
    for (int i = 3; i <= 10; i++) {
        Deal d;
        d.contractNumber = to_string(100 + i);
        d.date = "2024";
        d.owner = owners[rand() % 4];
        d.price = 50000 + rand() % 100000;
        d.salePeriod = 10 + rand() % 60;
        d.status = status[rand() % 2];

        table.Insert(d);
    }
}

int main() {
    srand(time(0));

    HashTable table(5); // маленький размер для коллизий

    GenerateDeals(table);

    table.PrintTable();

    cout << "\nПоиск по владельцу 'Иванов':\n";
    table.FindByOwner("Иванов");

    cout << "\nПоиск по владельцу 'ИвановX':\n";
    table.FindByOwner("ИвановX");
}
