#include <iostream>
#include <string>
#include <cstdlib>
#include <ctime>
#include <chrono>

using namespace std;

struct Deal {
    string contractNumber;
    string date;
    string owner;
    double price;
    int salePeriod;
    string status;
};

struct Node {
    string key;
    Deal value;
    Node* next;

    Node(string k, Deal v) {
        key = k;
        value = v;
        next = nullptr;
    }
};

int hash_func(string s, int size) {

    unsigned long long H = 0;
    unsigned long long p = 31;
    const unsigned long long M = 1315423911ULL;

    for (unsigned char a : s) {
        H = (H + (unsigned long long)a * p) % M;
        p = (p * p) % M;
    }

    return H % size;
}

class HashTable {

private:

    int SIZE;
    Node** buckets;

public:

    HashTable(int size) {

        SIZE = size;
        buckets = new Node*[SIZE];

        for (int i = 0; i < SIZE; i++)
            buckets[i] = nullptr;
    }

    void Insert(string key, Deal value) {

        int idx = hash_func(key, SIZE);

        Node* node = new Node(key, value);
        node->next = buckets[idx];
        buckets[idx] = node;
    }

    void FindByOwner(string owner) {

        int idx = hash_func(owner, SIZE);
        Node* cur = buckets[idx];

        while (cur) {

            if (cur->key == owner) {

                cout << cur->value.contractNumber << " "
                     << cur->value.owner << " "
                     << cur->value.price << endl;
            }

            cur = cur->next;
        }
    }
};

struct Dictionary {

    Deal data[100];
    int size = 0;

    void Insert(Deal d) {

        data[size++] = d;
    }

    void FindByOwner(string owner) {

        for (int i = 0; i < size; i++) {

            if (data[i].owner == owner) {

                cout << data[i].contractNumber << " "
                     << data[i].owner << " "
                     << data[i].price << endl;
            }
        }
    }
};

void GenerateDeals(HashTable& table, Dictionary& dict, int count) {

    string owners[] = {"Иванов","Петров","Сидоров","Смирнов","Кузнецов"};
    string status[] = {"успех","провал"};

    for (int i = 0; i < count; i++) {

        Deal d;

        d.contractNumber = to_string(100 + i);
        d.date = "2024";

        d.owner = owners[rand() % 5];

        d.price = 50000 + rand() % 100000;

        d.salePeriod = 10 + rand() % 60;

        d.status = status[rand() % 2];

        table.Insert(d.owner, d);
        dict.Insert(d);
    }
}

int main() {

    srand(time(0));

    HashTable table(50);
    Dictionary dict;

    GenerateDeals(table, dict, 50);

    string target = "Иванов";

    cout << "Поиск в словаре:\n";

    auto start1 = chrono::high_resolution_clock::now();

    dict.FindByOwner(target);

    auto end1 = chrono::high_resolution_clock::now();

    auto timeDict =
    chrono::duration_cast<chrono::nanoseconds>(end1 - start1);


    cout << "\nПоиск в хеш таблице:\n";

    auto start2 = chrono::high_resolution_clock::now();

    table.FindByOwner(target);

    auto end2 = chrono::high_resolution_clock::now();

    auto timeHash =
    chrono::duration_cast<chrono::nanoseconds>(end2 - start2);


    cout << "\nВремя поиска в словаре: "
         << timeDict.count() << " ns\n";

    cout << "Время поиска в хеш таблице: "
         << timeHash.count() << " ns\n";

}
